# Sepolia RPC — get from Infura or Alchemy
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Platform wallet private key (funded with Sepolia ETH)
# NEVER commit the real key — this is just a template
PLATFORM_WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Etherscan API key — for contract verification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Set to true to see gas usage in test output
REPORT_GAS=false
