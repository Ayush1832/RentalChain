{
  "name": "rentalchain",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/contracts",
    "packages/backend",
    "packages/frontend",
    "packages/mobile"
  ],
  "scripts": {
    "contracts": "npm run --workspace=packages/contracts",
    "backend": "npm run --workspace=packages/backend",
    "frontend": "npm run --workspace=packages/frontend",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,sol}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-solidity": "^1.4.1"
  }
}
